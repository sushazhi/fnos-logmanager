#!/bin/bash

echo "正在初始化飞牛日志管理安装..."

if ! mkdir -p "${TRIM_PKGVAR}"; then
    echo "Error: 无法创建数据目录 ${TRIM_PKGVAR}" > "$TRIM_TEMP_LOGFILE"
    exit 1
fi

if ! mkdir -p "${TRIM_PKGTMP}"; then
    echo "Error: 无法创建临时目录 ${TRIM_PKGTMP}" > "$TRIM_TEMP_LOGFILE"
    exit 1
fi

BACKUP_DIR="/vol1/@appshare/logmanager/backup"

if ! mkdir -p "$BACKUP_DIR"; then
    echo "Error: 无法创建备份目录 $BACKUP_DIR" > "$TRIM_TEMP_LOGFILE"
    exit 1
fi

NODE_PATH="/var/apps/nodejs_v24/target/bin/node"
if [ ! -f "$NODE_PATH" ]; then
    echo "Error: 未找到 Node.js 环境，请先安装 Node.js v24" > "$TRIM_TEMP_LOGFILE"
    exit 1
fi

echo "安装初始化完成"
exit 0
