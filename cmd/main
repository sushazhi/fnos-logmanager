#!/bin/bash

APP_NAME="logmanager"
LOG_FILE="${TRIM_PKGVAR}/info.log"
PID_FILE="${TRIM_PKGVAR}/app.pid"
SERVER_DIR="${TRIM_APPDEST}/server"

export PATH=/var/apps/nodejs_v24/target/bin:$PATH

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> ${LOG_FILE}
}

error_exit() {
    local msg="$1"
    echo "Error: $msg" > "$TRIM_TEMP_LOGFILE"
    log_msg "ERROR: $msg"
    exit 1
}

start_process() {
    if status; then
        log_msg "$APP_NAME is already running"
        return 0
    fi
    
    log_msg "Starting $APP_NAME..."
    
    if ! mkdir -p "${TRIM_PKGVAR}"; then
        error_exit "无法创建数据目录 ${TRIM_PKGVAR}"
    fi
    
    CONFIG_FILE="${TRIM_PKGVAR}/config/config.json"
    BACKUP_DIR="/vol1/@appshare/logmanager/backup"
    if [ -f "$CONFIG_FILE" ]; then
        CONFIG_BACKUP=$(grep -o '"backup_dir"[[:space:]]*:[[:space:]]*"[^"]*"' "$CONFIG_FILE" 2>/dev/null | grep -o '"[^"]*"$' | tr -d '"')
        if [ -n "$CONFIG_BACKUP" ]; then
            BACKUP_DIR="$CONFIG_BACKUP"
        fi
    fi
    if ! mkdir -p "$BACKUP_DIR"; then
        error_exit "无法创建备份目录 $BACKUP_DIR"
    fi
    
    FILTER_FILE="${TRIM_PKGVAR}/.filter_sensitive"
    
    if [ -f "$FILTER_FILE" ]; then
        FILTER_SENSITIVE=$(cat "$FILTER_FILE" 2>/dev/null)
    else
        FILTER_SENSITIVE="true"
    fi
    
    if [ ! -d "$SERVER_DIR" ]; then
        log_msg "TRIM_APPDEST=$TRIM_APPDEST"
        log_msg "SERVER_DIR=$SERVER_DIR"
        log_msg "检查目录结构:"
        ls -la "$TRIM_APPDEST" 2>&1 | head -20 >> ${LOG_FILE} || log_msg "无法列出 TRIM_APPDEST 目录"
        if [ -d "$TRIM_APPDEST/app" ]; then
            ls -la "$TRIM_APPDEST/app" 2>&1 >> ${LOG_FILE}
        else
            log_msg "TRIM_APPDEST/app 目录不存在"
        fi
        error_exit "服务器目录不存在: $SERVER_DIR"
    fi
    
    cd "$SERVER_DIR" || error_exit "无法进入服务器目录: $SERVER_DIR"
    
    if [ ! -d "$SERVER_DIR/node_modules" ]; then
        log_msg "Installing dependencies..."
        npm config set registry https://registry.npmmirror.com --location=project 2>/dev/null || true
        if ! npm install --production >> ${LOG_FILE} 2>&1; then
            error_exit "依赖安装失败，请检查网络连接"
        fi
    else
        log_msg "Dependencies already installed"
    fi
    
    if [ ! -f "$SERVER_DIR/server.js" ]; then
        error_exit "服务器文件不存在: $SERVER_DIR/server.js"
    fi
    
    GATEWAY_SOCKET=""
    if [ -n "${TRIM_APPDEST}" ]; then
        GATEWAY_SOCKET="${TRIM_APPDEST}/logmanager.sock"
        rm -f "$GATEWAY_SOCKET" 2>/dev/null
    fi
    
    LOGMANAGER_DATA_DIR="${TRIM_PKGVAR}" BACKUP_BASE_DIR="$BACKUP_DIR" FILTER_SENSITIVE="$FILTER_SENSITIVE" GATEWAY_SOCKET="$GATEWAY_SOCKET" node "$SERVER_DIR/server.js" >> ${LOG_FILE} 2>&1 &
    local pid=$!
    printf "%s" "$pid" > "$PID_FILE"
    
    sleep 2
    
    if check_process "$pid"; then
        log_msg "$APP_NAME started successfully"
        echo ""
        echo "=========================================="
        echo "  飞牛应用日志管理已启动"
        echo "  访问地址: 通过统一网关 /app/logmanager"
        echo "  数据目录: ${TRIM_PKGVAR}"
        echo "  日志: cat ${TRIM_PKGVAR}/info.log"
        echo "=========================================="
        echo ""
        return 0
    else
        error_exit "服务启动失败，请查看日志: ${LOG_FILE}"
    fi
}

stop_process() {
    log_msg "Stopping $APP_NAME..."
    
    if [ -r "$PID_FILE" ]; then
        pid=$(head -n 1 "$PID_FILE" | tr -d '[:space:]')
        
        if ! check_process "$pid"; then
            rm -f "$PID_FILE"
            return 0
        fi
        
        kill -TERM "$pid" >> ${LOG_FILE} 2>&1
        
        local count=0
        while check_process "$pid" && [ $count -lt 10 ]; do
            sleep 1
            count=$((count + 1))
        done
        
        if check_process "$pid"; then
            kill -KILL "$pid" 2>/dev/null
            sleep 1
        fi
        
        rm -f "$PID_FILE"
    fi
    
    log_msg "$APP_NAME stopped"
    return 0
}

check_process() {
    local pid=$1
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
        return 0
    else
        return 1
    fi
}

status() {
    if [ -f "$PID_FILE" ]; then
        pid=$(head -n 1 "$PID_FILE" | tr -d '[:space:]')
        if check_process "$pid"; then
            echo "$APP_NAME is running (PID: $pid)"
            return 0
        else
            rm -f "$PID_FILE"
        fi
    fi
    
    echo "$APP_NAME is not running"
    return 3
}

case "$1" in
    start)
        start_process
        ;;
    stop)
        stop_process
        ;;
    restart)
        stop_process
        sleep 2
        start_process
        ;;
    status)
        status
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac
