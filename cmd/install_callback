#!/bin/bash

echo "正在配置飞牛应用日志管理..."

APP_NAME="logmanager"
SERVER_DIR="${TRIM_APPDEST}/server"

BACKUP_DIR="/vol1/@appshare/logmanager/backup"

# 创建配置文件（已存在则不覆盖）
if [ ! -f "${TRIM_PKGVAR}/config.json" ]; then
cat > "${TRIM_PKGVAR}/config.json" << EOF
{
    "log_dirs": [
        "/vol1/@appdata",
        "/vol1/@appconf",
        "/vol1/@apphome",
        "/vol1/@apptemp",
        "/vol1/@appshare",
        "/var/log/apps"
    ],
    "backup_dir": "$BACKUP_DIR",
    "archive_extensions": [
        ".gz", ".bz2", ".xz", ".zip",
        ".tar", ".tar.gz", ".tar.bz2", ".tar.xz", ".7z", ".rar"
    ],
    "log_patterns": [
        "*.log", "*.log.*", "*log*.txt"
    ]
}
EOF
fi

if [ $? -ne 0 ]; then
    echo "Error: 无法创建配置文件" > "$TRIM_TEMP_LOGFILE"
    exit 1
fi

FILTER_SENSITIVE="${wizard_filter_sensitive:-true}"
if ! echo "$FILTER_SENSITIVE" > "${TRIM_PKGVAR}/.filter_sensitive"; then
    echo "Error: 无法保存过滤设置" > "$TRIM_TEMP_LOGFILE"
    exit 1
fi

# 验证服务器文件
# 注意：install_callback 在 install-local 过程中执行
# 此时新文件可能还未完全移动到 TRIM_APPDEST
# 因此跳过严格的文件验证，依赖 install-local 的完整性检查
echo "安装回调执行完成，依赖系统完成文件安装" >> "$TRIM_TEMP_LOGFILE"

echo "飞牛应用日志管理配置完成"
echo "请首次访问时设置登录密码"
exit 0
